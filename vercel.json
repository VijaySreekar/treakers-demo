{
  "functions": {
    "api/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    { "src": "^/$", "dest": "/api/index.php?__path=/" },
    { "src": "^/(.*\\.php)$", "dest": "/api/index.php?__path=/$1" },
    { "handle": "filesystem" },
    { "src": "^/(.*)$", "dest": "/api/index.php?__path=/$1" }
  ]
}
